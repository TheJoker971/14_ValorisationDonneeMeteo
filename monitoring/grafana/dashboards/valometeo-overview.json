{
  "uid": "valometeo-overview",
  "title": "ValoMeteo - Overview",
  "tags": ["valometeo", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "DS_PROM",
        "label": "Datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Targets UP (sum)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 5 },
      "targets": [
        { "refId": "A", "expr": "sum(up)", "legendFormat": "up" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Scrape duration (p95) by job",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "x": 8, "y": 0, "w": 16, "h": 5 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, job) (rate(scrape_duration_seconds_bucket[5m])))",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Django HTTP requests (rate)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 7 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (method) (rate(django_http_requests_total[5m]))",
          "legendFormat": "{{method}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Django request latency (p95)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 7 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le) (rate(django_http_requests_latency_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Nginx connections",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 7 },
      "targets": [
        { "refId": "A", "expr": "nginx_connections_active", "legendFormat": "active" },
        { "refId": "B", "expr": "nginx_connections_reading", "legendFormat": "reading" },
        { "refId": "C", "expr": "nginx_connections_writing", "legendFormat": "writing" },
        { "refId": "D", "expr": "nginx_connections_waiting", "legendFormat": "waiting" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Postgres transactions (rate)",
      "datasource": { "type": "prometheus", "uid": "${DS_PROM}" },
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 7 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(pg_stat_database_xact_commit[5m]) + rate(pg_stat_database_xact_rollback[5m]))",
          "legendFormat": "xact/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    }
  ]
}
